generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum GameStatus {
  APPROVED
  PENDING
}

enum EventType {
  LEAGUE
  TOURNAMENT
}

enum ClassificationSystem {
  ELO
  POINTS
}

enum PhaseType {
  ROUND_ROBIN
  ELO_RATING
  SWISS
  SINGLE_ELIMINATION
  DOUBLE_ELIMINATION
  GROUP_STAGE
}

enum MatchOutcome {
  WIN
  DRAW
  LOSS
}

enum EventStatus {
  PENDING
  ACTIVE
  FINISHED
  CANCELLED
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum AttachmentType {
  IMAGE
  VIDEO
}

enum VideoPlatform {
  TWITCH
  YOUTUBE
  OTHER
}

enum MatchFormat {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FOUR_V_FOUR
  FIVE_V_FIVE
  SIX_V_SIX
  FREE_FOR_ALL
}

enum ParticipationMode {
  SOLO
  TEAM
}

enum PermissionKey {
  manage_games
  manage_events
  manage_users
}

enum EventStaffRole {
  ORGANIZER
  MODERATOR
  SCOREKEEPER
}

enum ClaimInitiator {
  STAFF
  USER
}

enum EntryClaimStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// --- AUTH MODELS ---

model User {
  id                  String    @id @default(cuid())
  name                String
  username            String    @unique
  email               String?   @unique
  emailVerified       DateTime? @map("email_verified")
  imageUrl            String?   @map("image_url")
  bio                 String?
  profileColor        String?   @map("profile_color")
  country             String?
  isAdmin             Boolean   @default(false) @map("is_admin")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")

  accounts        Account[]
  sessions        Session[]
  authoredGames   Game[]
  authoredEvents  Event[]
  userPermissions UserPermission[]
  auditLogs       AuditLog[]

  // Competition links
  eventEntries         EventEntry[]         @relation("ConfirmedEntry")
  teamMemberships      TeamMember[]         @relation("ConfirmedMember")
  staffRoles           EventStaff[]
  entryClaims          EntryClaim[]         @relation("ClaimRequester")
  claimsReviewed       EntryClaim[]         @relation("ClaimReviewer")
  memberClaims         TeamMemberClaim[]    @relation("MemberClaimRequester")
  memberClaimsReviewed TeamMemberClaim[]    @relation("MemberClaimReviewer")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  token     String   @db.Text
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("auth_codes")
}


// --- DOMAIN MODELS ---

model Game {
  id                 String     @id @default(cuid())
  name               String     @unique
  slug               String     @unique
  description        String?
  backgroundImageUrl String?    @map("background_image_url")
  thumbnailImageUrl  String?    @map("thumbnail_image_url") // Tip: Usually 460x215
  steamUrl           String?    @map("steam_url")
  websiteUrl         String?    @map("website_url")
  status             GameStatus @default(APPROVED)
  authorId           String?    @map("author_id")

  author User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  events Event[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("games")
}

model Event {
  id     String @id @default(cuid())
  gameId String @map("game_id")
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  type              EventType
  participationMode ParticipationMode @default(SOLO) @map("participation_mode")
  status            EventStatus       @default(PENDING)
  visibility        EventVisibility   @default(PUBLIC)

  name        String
  slug        String
  description String?
  about       String?

  startDate             DateTime? @map("start_date")
  endDate               DateTime? @map("end_date")
  registrationsEnabled  Boolean   @default(false) @map("registrations_enabled")
  registrationStartDate DateTime? @map("registration_start_date")
  registrationEndDate   DateTime? @map("registration_end_date")
  maxParticipants       Int?      @map("max_participants")
  officialLinks         Json?     @map("official_links")
  approvedAt            DateTime? @map("approved_at")

  authorId String? @map("author_id")
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Extensions by type
  league     League?
  tournament Tournament?

  // Participants, staff, matches, media
  entries     EventEntry[]
  staff       EventStaff[]
  matches     Match[]
  attachments EventAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([gameId, slug])
  @@map("events")
}

// 1:1 extension of Event when type = LEAGUE
model League {
  eventId String @id @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  classificationSystem ClassificationSystem @default(ELO) @map("classification_system")

  // Classification config as JSON
  // ELO:    { initialElo, kFactor, scoreRelevance, inactivityDecay,
  //           inactivityThresholdHours, inactivityDecayFloor }
  // POINTS: { pointsPerWin, pointsPerDraw, pointsPerLoss }
  config Json

  allowDraw      Boolean       @default(false) @map("allow_draw")
  allowedFormats MatchFormat[] @default([]) @map("allowed_formats")

  // Schema for organizer-defined dynamic stats fields per match
  // Ex.: [{ name: "kills", type: "number", label: "Kills" }]
  customFieldSchema Json? @map("custom_field_schema")

  @@map("leagues")
}

// 1:1 extension of Event when type = TOURNAMENT
model Tournament {
  eventId String @id @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Global tournament config (seeding strategy, progression rules, etc.)
  // Ex.: { seedingStrategy: "MANUAL", progressionMode: "TOP_N" }
  config Json

  // Schema for organizer-defined dynamic stats fields shared across phases
  customFieldSchema Json? @map("custom_field_schema")

  phases TournamentPhase[]

  @@map("tournaments")
}

// Ordered phase in a Tournament
model TournamentPhase {
  id           String     @id @default(cuid())
  tournamentId String     @map("tournament_id")
  tournament   Tournament @relation(fields: [tournamentId], references: [eventId], onDelete: Cascade)

  order  Int         // position in sequence (1, 2, 3…)
  name   String
  type   PhaseType
  status EventStatus @default(PENDING)

  // Phase config as JSON — shape depends on type
  // ROUND_ROBIN / ELO_RATING: same keys as League.config
  // SWISS:           { rounds, tiebreak }
  // SINGLE_ELIM:     { seedingStrategy, thirdPlaceMatch }
  // DOUBLE_ELIM:     { seedingStrategy }
  // GROUP_STAGE:     { groupCount, advancePerGroup, tiebreak }
  config Json

  allowDraw         Boolean       @default(false) @map("allow_draw")
  allowedFormats    MatchFormat[] @default([]) @map("allowed_formats")
  customFieldSchema Json?         @map("custom_field_schema")

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  matches      Match[]
  phaseEntries PhaseEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tournament_phases")
}

// A participant slot in an event — solo (userId) or team (members)
model EventEntry {
  id      String @id @default(cuid())
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  displayName String  @map("display_name")
  imageUrl    String? @map("image_url")

  // Confirmed solo user link — null if unlinked or team entry
  userId String? @map("user_id")
  user   User?   @relation("ConfirmedEntry", fields: [userId], references: [id], onDelete: SetNull)

  // Team members (populated when event.participationMode = TEAM)
  members TeamMember[]

  // Computed stats — updated after each processed match
  // ELO:    { currentElo: 1250 }
  // POINTS: { points: 9, wins: 3, draws: 0, losses: 1 }
  stats Json @default("{}")

  claims            EntryClaim[]
  matchParticipants MatchParticipant[]
  phaseEntries      PhaseEntry[]
  snapshots         EntrySnapshot[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([eventId, userId])
  @@map("event_entries")
}

// Daily snapshot of an entry's position and stats — populated by cron at midnight UTC
model EntrySnapshot {
  id      String     @id @default(cuid())
  entryId String     @map("entry_id")
  entry   EventEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  snapshotDate DateTime @map("snapshot_date") @db.Date
  position     Int
  stats        Json // copy of EventEntry.stats at snapshot time

  @@unique([entryId, snapshotDate])
  @@map("entry_snapshots")
}

// Entry's standing within a specific tournament phase
model PhaseEntry {
  id      String          @id @default(cuid())
  phaseId String          @map("phase_id")
  phase   TournamentPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  entryId String          @map("entry_id")
  entry   EventEntry      @relation(fields: [entryId], references: [id], onDelete: Cascade)

  stats    Json @default("{}")
  position Int? // static after phase ends
  seed     Int?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([phaseId, entryId])
  @@map("phase_entries")
}

// Individual member of a team entry
model TeamMember {
  id      String     @id @default(cuid())
  entryId String     @map("entry_id")
  entry   EventEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  displayName String  @map("display_name")
  imageUrl    String? @map("image_url")

  userId String? @map("user_id")
  user   User?   @relation("ConfirmedMember", fields: [userId], references: [id], onDelete: SetNull)

  claims TeamMemberClaim[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

// Claim on a solo entry
// initiatedBy = STAFF  → staff invited user   → user must accept
// initiatedBy = USER   → user requested entry → staff must accept
model EntryClaim {
  id      String     @id @default(cuid())
  entryId String     @map("entry_id")
  entry   EventEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId  String     @map("user_id")
  user    User       @relation("ClaimRequester", fields: [userId], references: [id], onDelete: Cascade)

  initiatedBy ClaimInitiator   @map("initiated_by")
  status      EntryClaimStatus @default(PENDING)
  message     String?

  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("ClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([entryId, userId])
  @@map("entry_claims")
}

// Claim on a team member slot — same bidirectional logic as EntryClaim
model TeamMemberClaim {
  id       String     @id @default(cuid())
  memberId String     @map("member_id")
  member   TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  userId   String     @map("user_id")
  user     User       @relation("MemberClaimRequester", fields: [userId], references: [id], onDelete: Cascade)

  initiatedBy ClaimInitiator   @map("initiated_by")
  status      EntryClaimStatus @default(PENDING)
  message     String?

  reviewedById String?   @map("reviewed_by_id")
  reviewedBy   User?     @relation("MemberClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime? @map("reviewed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([memberId, userId])
  @@map("team_member_claims")
}

// Staff and moderators of an event
// The event author is automatically inserted as ORGANIZER on creation
model EventStaff {
  id      String @id @default(cuid())
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role EventStaffRole @default(MODERATOR)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([eventId, userId])
  @@map("event_staff")
}

// Match — can be scheduled (scheduledAt, no playedAt) or registered (playedAt set)
model Match {
  id      String @id @default(cuid())
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // Present in tournaments — identifies which phase this match belongs to
  phaseId String?          @map("phase_id")
  phase   TournamentPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  format      MatchFormat
  description String?

  scheduledAt DateTime? @map("scheduled_at")
  playedAt    DateTime? @map("played_at")

  participants MatchParticipant[]
  attachments  MatchAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("matches")
}

// One entry's (solo or team) participation in a match
model MatchParticipant {
  id      String     @id @default(cuid())
  matchId String     @map("match_id")
  match   Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  entryId String     @map("entry_id")
  entry   EventEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  outcome      MatchOutcome
  score        Int?  // raw score (optional)
  ratingChange Int?  @map("rating_change") // eloDifference or pointsGained

  // Organizer-defined dynamic fields
  // Ex.: { "kills": 12, "deaths": 3, "assists": 7 }
  customStats Json? @map("custom_stats")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([matchId, entryId])
  @@map("match_participants")
}

model MatchAttachment {
  id            String         @id @default(cuid())
  matchId       String         @map("match_id")
  match         Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type          AttachmentType
  videoPlatform VideoPlatform? @map("video_platform")
  url           String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("match_attachments")
}

model EventAttachment {
  id            String         @id @default(cuid())
  eventId       String         @map("event_id")
  event         Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  type          AttachmentType
  videoPlatform VideoPlatform? @map("video_platform")
  url           String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("event_attachments")
}

model UserPermission {
  id     String        @id @default(cuid())
  userId String        @map("user_id")
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    PermissionKey

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, key])
  @@map("user_permissions")
}

// --- LOGGING ---

model AuditLog {
  id     String  @id @default(cuid())
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String // E.g. "GAME_APPROVED"
  description String // E.g. "Approved game Superfighters Deluxe"

  entityType String @map("entity_type") // GAME, EVENT, etc.
  entityId   String @map("entity_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
