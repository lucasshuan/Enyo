generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum GameStatus {
  APPROVED
  PENDING
}

enum EventType {
  RANKED_LEAGUE
  STANDARD_LEAGUE
  TOURNAMENT
}

enum MatchOutcome {
  WIN
  DRAW
  LOSS
}

enum EventStatus {
  PENDING
  ACTIVE
  FINISHED
  CANCELLED
}

enum ResultAttachmentType {
  IMAGE
  VIDEO
}

enum VideoPlatform {
  TWITCH
  YOUTUBE
  OTHER
}

enum MatchFormat {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FOUR_V_FOUR
  FIVE_V_FIVE
  SIX_V_SIX
  FREE_FOR_ALL
}

enum ParticipationMode {
  SOLO
  TEAM
}

enum PermissionKey {
  manage_games
  manage_players
  manage_events
  manage_users
}

// --- AUTH MODELS ---

model User {
  id            String    @id @default(cuid())
  name          String
  username      String    @unique
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  imageUrl         String?   @map("image_url")
  bio           String?
  profileColor  String?   @map("profile_color")
  country       String?
  isAdmin       Boolean   @default(false) @map("is_admin")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")

  accounts        Account[]
  sessions        Session[]
  authoredGames   Game[]
  players         Player[]
  userPermissions UserPermission[]
  auditLogs       AuditLog[]
  authoredEvents  Event[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AuthCode {
  id        String   @id @default(cuid())
  code      String   @unique
  token     String   @db.Text
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("auth_codes")
}


// --- DOMAIN MODELS ---

model Game {
  id                 String     @id @default(cuid())
  name               String     @unique
  slug               String     @unique
  description        String?
  backgroundImageUrl String?    @map("background_image_url")
  thumbnailImageUrl  String?    @map("thumbnail_image_url") // Tip: Usually 460x215
  steamUrl           String?    @map("steam_url")
  websiteUrl         String?    @map("website_url")
  status             GameStatus @default(APPROVED)
  authorId           String?    @map("author_id")

  author  User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  events  Event[]
  players Player[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("games")
}

model Event {
  id     String @id @default(cuid())
  gameId String @map("game_id")
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  type              EventType
  participationMode ParticipationMode @default(SOLO) @map("participation_mode")
  status            EventStatus       @default(PENDING)

  name        String
  slug        String
  description String?
  about       String?

  startDate  DateTime? @map("start_date")
  endDate    DateTime? @map("end_date")
  approvedAt DateTime? @map("approved_at")

  authorId String? @map("author_id")
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  // Specific extensions
  eloLeague      EloLeague?
  standardLeague StandardLeague?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([gameId, slug])
  @@map("events")
}

model EloLeague {
  eventId String @id @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  initialElo     Int     @default(1000) @map("initial_elo")
  allowDraw      Boolean @default(false) @map("allow_draw")
  kFactor        Int     @default(20) @map("k_factor")
  scoreRelevance Float   @default(0.4) @map("score_relevance")

  inactivityDecay          Int @default(5) @map("inactivity_decay")
  inactivityThresholdHours Int @default(120) @map("inactivity_threshold_hours")
  inactivityDecayFloor     Int @default(1000) @map("inactivity_decay_floor")

  allowedFormats MatchFormat[] @default([]) @map("allowed_formats")

  entries EloLeagueEntry[]
  results EloResult[]

  @@map("elo_leagues")
}

model StandardLeague {
  eventId String @id @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  allowDraw     Boolean @default(false) @map("allow_draw")
  pointsPerWin  Int     @default(3) @map("points_per_win")
  pointsPerDraw Int     @default(1) @map("points_per_draw")
  pointsPerLoss Int     @default(0) @map("points_per_loss")

  allowedFormats MatchFormat[] @default([]) @map("allowed_formats")

  entries StandardLeagueEntry[]
  results StandardResult[]

  @@map("standard_leagues")
}

model Player {
  id                String  @id @default(cuid())
  gameId            String  @map("game_id")
  game              Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId            String? @map("user_id")
  user              User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  primaryUsernameId String? @map("primary_username_id")

  usernames             PlayerUsername[]
  eloLeagueEntries      EloLeagueEntry[]
  standardLeagueEntries StandardLeagueEntry[]
  eloResultEntries      EloResultEntry[]
  standardResultEntries StandardResultEntry[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([gameId, userId])
  @@map("players")
}

model PlayerUsername {
  id       String @id @default(cuid())
  playerId String @map("player_id")
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  username String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([playerId, username])
  @@map("player_usernames")
}

model EloLeagueEntry {
  id       String     @id @default(cuid())
  leagueId String     @map("event_id")
  league   EloLeague  @relation(fields: [leagueId], references: [eventId], onDelete: Cascade)
  playerId String     @map("player_id")
  player   Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  currentElo Int @default(1000) @map("current_elo")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([leagueId, playerId])
  @@map("elo_league_entries")
}

model StandardLeagueEntry {
  id       String         @id @default(cuid())
  leagueId String         @map("event_id")
  league   StandardLeague @relation(fields: [leagueId], references: [eventId], onDelete: Cascade)
  playerId String         @map("player_id")
  player   Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  points Int @default(0)
  wins   Int @default(0)
  draws  Int @default(0)
  losses Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([leagueId, playerId])
  @@map("standard_league_entries")
}

model EloResult {
  id       String    @id @default(cuid())
  leagueId String    @map("event_id")
  league   EloLeague @relation(fields: [leagueId], references: [eventId], onDelete: Cascade)

  description String?
  format      MatchFormat

  entries     EloResultEntry[]
  attachments EloResultAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("elo_results")
}

model EloResultEntry {
  id       String    @id @default(cuid())
  resultId String    @map("result_id")
  result   EloResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  playerId String    @map("player_id")
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  eloDifference Int @map("elo_difference")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resultId, playerId])
  @@map("elo_result_entries")
}

model EloResultAttachment {
  id            String               @id @default(cuid())
  resultId      String               @map("result_id")
  result        EloResult            @relation(fields: [resultId], references: [id], onDelete: Cascade)
  type          ResultAttachmentType
  videoPlatform VideoPlatform?       @map("video_platform")
  url           String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("elo_result_attachments")
}

model StandardResult {
  id       String         @id @default(cuid())
  leagueId String         @map("event_id")
  league   StandardLeague @relation(fields: [leagueId], references: [eventId], onDelete: Cascade)

  description String?
  format      MatchFormat

  entries     StandardResultEntry[]
  attachments StandardResultAttachment[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("standard_results")
}

model StandardResultEntry {
  id       String         @id @default(cuid())
  resultId String         @map("result_id")
  result   StandardResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  playerId String         @map("player_id")
  player   Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  outcome      MatchOutcome
  score        Int
  pointsGained Int          @map("points_gained")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([resultId, playerId])
  @@map("standard_result_entries")
}

model StandardResultAttachment {
  id            String               @id @default(cuid())
  resultId      String               @map("result_id")
  result        StandardResult       @relation(fields: [resultId], references: [id], onDelete: Cascade)
  type          ResultAttachmentType
  videoPlatform VideoPlatform?       @map("video_platform")
  url           String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("standard_result_attachments")
}

model UserPermission {
  id     String        @id @default(cuid())
  userId String        @map("user_id")
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  key    PermissionKey

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, key])
  @@map("user_permissions")
}

// --- LOGGING ---

model AuditLog {
  id     String  @id @default(cuid())
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      String // E.g. "GAME_APPROVED"
  description String // E.g. "Approved game Superfighters Deluxe"

  entityType String @map("entity_type") // GAME, EVENT, etc.
  entityId   String @map("entity_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}
