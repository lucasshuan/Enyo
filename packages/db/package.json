{
  "name": "@bellona/db",
  "version": "0.1.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "build": "prisma generate --schema=./prisma/schema.prisma",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "format": "prettier --write . --cache",
    "lint": "eslint . --max-warnings=0 --cache --cache-location .eslintcache",
    "postinstall": "node -e \"if (process.env.CI || process.env.VERCEL || process.env.RENDER) process.exit(0); const { spawnSync } = require('node:child_process'); const result = spawnSync('prisma generate --schema=./prisma/schema.prisma', { stdio: 'inherit', shell: true }); if (result.error) throw result.error; process.exit(result.status ?? 0);\"",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma",
    "seed": "node --env-file=.env --import tsx ./prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@theinternetfolks/snowflake": "1.3.0",
    "pg": "^8.20.0"
  },
  "peerDependencies": {
    "next-auth": "4.24.13"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "next-auth": "4.24.13",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "5.7.3"
  }
}
