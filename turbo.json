{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json", "tsconfig.json"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["NODE_ENV"]
    },
    "codegen": {
      "inputs": [
        "src/lib/apollo/queries/**/*.ts",
        "codegen.js",
        "../api/src/schema.gql"
      ],
      "outputs": ["src/lib/apollo/generated/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        ".eslintrc*",
        "eslint.config*",
        "../../.eslintrc*"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "../../tsconfig.json"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "codegen:watch": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "inputs": [
        "src/**",
        "package.json",
        ".prettierrc*",
        "../../.prettierrc*",
        "../../.prettierignore"
      ]
    }
  }
}
