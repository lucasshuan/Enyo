{
  "name": "bellona-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev codegen:watch",
    "dev:web": "turbo run dev --filter @bellona/web",
    "dev:api": "turbo run dev --filter @bellona/api",
    "db:migrate": "turbo run migrate --filter @bellona/db",
    "db:seed": "pnpm --filter @bellona/db exec prisma db seed",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format || true",
    "typecheck": "turbo run typecheck",
    "prepare": "node -e \"if (process.env.CI || process.env.VERCEL || process.env.RENDER) process.exit(0); const { spawnSync } = require('node:child_process'); const result = spawnSync('husky', { stdio: 'inherit', shell: true }); if (result.error) throw result.error; process.exit(result.status ?? 0);\""
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.7"
  },
  "lint-staged": {
    "apps/web/src/lib/apollo/queries/**/*.ts": [
      "pnpm -C apps/web codegen"
    ],
    "apps/web/**/*.{ts,tsx,js,mjs}": [
      "pnpm -C apps/web exec eslint --fix",
      "prettier --write --cache"
    ],
    "apps/api/**/*.ts": [
      "pnpm -C apps/api exec eslint --fix",
      "prettier --write --cache"
    ],
    "packages/core/**/*.{ts,tsx,js,mjs}": [
      "pnpm -C packages/core exec eslint --fix",
      "prettier --write --cache"
    ],
    "packages/db/**/*.{ts,tsx,js,mjs}": [
      "pnpm -C packages/db exec eslint --fix",
      "prettier --write --cache"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write --cache"
    ]
  },
  "packageManager": "pnpm@9.1.1"
}
